# Reuse the same Google Cloud OAuth client as gdoc-markdown / benbox.
# In Google Cloud Console, the project owning these creds must have:
#   - Google Slides API enabled
#   - Google Drive API enabled
# OAuth consent screen scopes:
#   https://www.googleapis.com/auth/presentations
#   https://www.googleapis.com/auth/drive.file
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4242/oauth2callback
